# config.yaml — your personal configuration
# ─────────────────────────────────────────
# Generated by: python3 setup.py
# Or copy this to ~/.openclaw/config.yaml and fill in manually.
# This file is gitignored — never committed.
#
# Lock permissions: chmod 600 ~/.openclaw/config.yaml

# ── Your Info ────────────────────────────────────────────────────────────────
user:
  name: "Your Name"
  location: "Your City, State"
  latitude: 40.7128        # Auto-set by setup.py geocoding
  longitude: -74.0060      # Auto-set by setup.py geocoding
  timezone: "America/New_York"
  personality: "casual"    # casual | professional | minimal
  assistant_name: "Rout"

# ── iMessage Chats ───────────────────────────────────────────────────────────
# Run `imsg chats --json` to find your chat ID (the row number).
# personal_id is your 1:1 chat (usually 1).
chats:
  personal_id: 1
  group_ids: []

# ── Chat Handles (for sending replies) ──────────────────────────────────────
# Maps chat_id -> [handle, type]
# type = "buddy" for 1:1 chats, "chat" for group threads.
chat_handles:
  1: ["+15551234567", "buddy"]

# ── Known Senders ────────────────────────────────────────────────────────────
known_senders:
  "+15551234567": "Your Name"

# ── Claude API ───────────────────────────────────────────────────────────────
anthropic_api_key: "sk-ant-XXXXXXXXX"

# ── Binary Paths (optional overrides) ───────────────────────────────────────
paths:
  python: "/usr/bin/python3"
  imsg: "/opt/homebrew/bin/imsg"
  codex: "/Applications/Codex.app/Contents/Resources/codex"

# ── Codex Fallback (optional) ───────────────────────────────────────────────
codex:
  enabled: true
  model: ""
  timeout_seconds: 120

# ── Local Model Fallback (optional) ─────────────────────────────────────────
# Last-resort fallback when cloud providers are rate-limited.
# Install: brew install ollama && ollama pull llama3.2
local_model:
  enabled: false
  provider: "ollama"
  host: "http://localhost:11434"
  model: "llama3.2:latest"
  timeout_seconds: 60
  max_tokens: 1024
  disclaimer: true

# ── Anthropic Settings ──────────────────────────────────────────────────────
anthropic:
  max_tokens: 512

# ── Watcher Settings ────────────────────────────────────────────────────────
watcher:
  history_limit: 10
