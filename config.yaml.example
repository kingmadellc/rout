# config.yaml — your personal configuration
# ─────────────────────────────────────────
# Generated by: python3 setup.py
# Or copy this to ~/.openclaw/config.yaml and fill in manually.
# This file is gitignored — never committed.
#
# Lock permissions: chmod 600 ~/.openclaw/config.yaml

# ── Your Info ────────────────────────────────────────────────────────────────
user:
  name: "Your Name"
  location: "Your City, State"
  latitude: 40.7128        # Auto-set by setup.py geocoding
  longitude: -74.0060      # Auto-set by setup.py geocoding
  timezone: "America/New_York"
  personality: "casual"    # casual | professional | minimal
  assistant_name: "Rout"

# ── iMessage Chats ───────────────────────────────────────────────────────────
# Run `imsg chats --json` to find your chat ID (the row number).
# personal_id is your 1:1 chat (usually 1).
chats:
  personal_id: 1
  group_ids: []

# ── Chat Handles (for sending replies) ──────────────────────────────────────
# Maps chat_id -> [handle, type]
# type = "buddy" for 1:1 chats, "chat" for group threads.
chat_handles:
  1: ["+15551234567", "buddy"]

# ── Known Senders ────────────────────────────────────────────────────────────
known_senders:
  "+15551234567": "Your Name"

# ── Mode Selection ───────────────────────────────────────────────────────────
# local_only: true  → All inference runs on-device via Ollama. No API keys needed.
# local_only: false → Cloud providers (Anthropic/Codex) with optional local fallback.
local_only: false

# ── Claude API (cloud mode only) ────────────────────────────────────────────
anthropic_api_key: "sk-ant-XXXXXXXXX"

# ── Binary Paths (optional overrides) ───────────────────────────────────────
paths:
  python: "/usr/bin/python3"
  imsg: "/opt/homebrew/bin/imsg"
  codex: "/Applications/Codex.app/Contents/Resources/codex"

# ── Codex Fallback (cloud mode only) ────────────────────────────────────────
codex:
  enabled: true
  model: ""
  timeout_seconds: 120

# ── Local Model ─────────────────────────────────────────────────────────────
# In local_only mode: this is your primary (and only) provider.
# In cloud mode: last-resort fallback when cloud providers are rate-limited.
#
# Setup (local-only): bash setup_local.sh
# Setup (fallback):   brew install ollama && ollama pull qwen3.5:27b
#
# Model recommendations by RAM:
#   16GB: qwen3.5:14b          (basic, fast)
#   32GB: qwen3.5:27b          (recommended — full tool calling, good quality)
#   48GB+: qwen3.5:35b-a3b     (MoE, best quality at this size)
#   64GB+: qwen3.5:32b         (dense, highest quality sub-70B)
local_model:
  enabled: false               # Set to true (or use local_only: true)
  provider: "ollama"
  host: "http://localhost:11434"
  model: "qwen3.5:27b"        # See recommendations above
  timeout_seconds: 120         # Local inference can be slower
  max_tokens: 4096
  temperature: 0.7
  context_length: 32768        # 32K context window
  gpu_memory_cap_mb: 24576     # For 32GB Mac: leave ~8GB for OS + apps
  tool_capable: false          # Enable Qwen function calling (requires Qwen 2.5+ or 3.5)
                               # When true, local provider handles tools like Anthropic —
                               # enables verification guard and full agent loop with tools.

# ── Anthropic Settings (cloud mode only) ─────────────────────────────────────
anthropic:
  max_tokens: 4096

# ── BlueBubbles Push Transport (optional) ─────────────────────────────────
# Real-time message delivery via Socket.IO instead of polling.
# Requires BlueBubbles server running on the same Mac.
# Install deps: pip install python-socketio[client] requests
# Setup: Open BB Server -> API & Webhooks -> copy your server password.
bluebubbles:
  enabled: false
  server_url: "http://localhost:1234"
  password: "your-bb-server-password"
  send_method: "private-api"       # "private-api" (recommended) or "apple-script"
  # Map your local chat_ids to BB chat GUIDs.
  # Find GUIDs: open BB Server -> Chats, or use bb.list_chats().
  chat_map:
    1: "iMessage;-;+15551234567"
    # 2: "iMessage;-;chat123456789"  # group chat example

# ── Polymarket (Public API — no auth, no SDK needed) ───────────────────────
# Read-only prediction market data. Works out of the box.
polymarket:
  enabled: true
  # Watchlist: market slugs to track (find slugs via 'trending' command)
  watchlist:
    # - "will-bitcoin-reach-100k-in-2026"
    # - "presidential-election-winner-2028"

# ── Watcher Settings ────────────────────────────────────────────────────────
watcher:
  history_limit: 10
